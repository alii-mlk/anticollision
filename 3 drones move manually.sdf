// spawn 3 drones and move them manually

// terminal1
// ros && gz sim ~/drone_demo/swarm_demo.sdf -s -v 4
// terminal 2
// ros && gz-gui

// Press Play in simulator, then in terminal 3
// ros
// gz topic -t /drone_1/gazebo/command/motor_speed --msgtype gz.msgs.Actuators -p 'velocity:[700, 700, 700, 700]'
// gz topic -t /drone_2/gazebo/command/motor_speed --msgtype gz.msgs.Actuators -p 'velocity:[700, 700, 700, 700]'
// gz topic -t /drone_3/gazebo/command/motor_speed --msgtype gz.msgs.Actuators -p 'velocity:[700, 700, 700, 700]'
