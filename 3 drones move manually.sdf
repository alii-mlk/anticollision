    <!-- ===== DRONE 3 ===== -->
    <include>
      <uri>/Users/ali/.gz/fuel/fuel.gazebosim.org/openrobotics/models/x3 uav/6</uri>
      <name>drone_3</name>
      <pose>0 3 0.3 0 0 0</pose>
      <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
